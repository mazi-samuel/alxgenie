# ─── Telegram ───────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# The channel/group to post weekly highlights to.
# For a public channel:  @yourchannel
# For a private channel or group, use its numeric ID e.g. -1001234567890
TELEGRAM_CHANNEL_ID=@your_channel_here

# Your personal Telegram user ID(s), comma-separated (get it from @userinfobot)
# Only these users can run admin commands like /schedule, /postweekly
# Example: ADMIN_USER_IDS=12345678,87654321
ADMIN_USER_IDS=123456789

# ─── Google Sheets ──────────────────────────────────────────
# The long ID found in your spreadsheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ─── Spreadsheet Layout ─────────────────────────────────────
# "tabs"   → each tab/sheet is a separate course  (RECOMMENDED)
# "column" → one sheet, courses identified by a "Course" column
SHEET_MODE=tabs

# Column names in your spreadsheet (case-insensitive)
COL_NAME=Name
COL_DATE=Completion Date
COL_WEEK=Week
# Only used when SHEET_MODE=column:
COL_COURSE=Course

# ─── Weekly Post Schedule ───────────────────────────────────
# Day of the week to auto-post Top 10 (mon/tue/wed/thu/fri/sat/sun)
WEEKLY_POST_DAY=mon
# Time to post (24-hour HH:MM format)
WEEKLY_POST_TIME=09:00

# ─── Timezone ───────────────────────────────────────────────
TIMEZONE=Africa/Lagos
